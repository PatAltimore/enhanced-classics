# ---------------------------------------------------------------
# Azure OpenAI  (gpt-4o / gpt-4o-mini)
# Azure AI Foundry → your project → Azure OpenAI → Keys and Endpoint
# ---------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_KEY=your-azure-openai-key-here
# Optional — defaults to 2024-12-01-preview
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ---------------------------------------------------------------
# Foundry serverless — Meta-Llama-3.3-70B-Instruct
# Azure AI Foundry → your project → Models + endpoints →
#   Meta-Llama-3.3-70B-Instruct → copy "Target URI" and "Key"
# Each serverless model has its own unique endpoint URL.
# ---------------------------------------------------------------
AZURE_LLAMA_ENDPOINT=https://YOUR-LLAMA-DEPLOYMENT.eastus.models.ai.azure.com
AZURE_LLAMA_KEY=your-llama-key-here

# ---------------------------------------------------------------
# Foundry serverless — Mistral-Large-3
# Azure AI Foundry → your project → Models + endpoints →
#   Mistral-Large-3 → copy "Target URI" and "Key"
# ---------------------------------------------------------------
AZURE_MISTRAL_ENDPOINT=https://YOUR-MISTRAL-DEPLOYMENT.eastus.models.ai.azure.com
AZURE_MISTRAL_KEY=your-mistral-key-here
