# ---------------------------------------------------------------
# Azure OpenAI  (gpt-4.1 / gpt-4o / gpt-4o-mini)
# Azure AI Foundry → your project → Azure OpenAI → Keys and Endpoint
# ---------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_KEY=your-azure-openai-key-here

# ---------------------------------------------------------------
# Azure AI Foundry serverless models  (Llama, Mistral, etc.)
# Azure AI Foundry → your project → Models + endpoints →
#   pick a serverless model → copy "Target URI" and "Key"
# Note: each serverless model has its own endpoint URL.
# Point this at whichever serverless model you want to use first;
# add more env vars and update _ENDPOINT_MAP in client.py if you
# want to route Llama and Mistral to separate endpoints.
# ---------------------------------------------------------------
AZURE_FOUNDRY_ENDPOINT=https://YOUR-PROJECT.eastus.models.ai.azure.com
AZURE_FOUNDRY_KEY=your-azure-foundry-key-here
